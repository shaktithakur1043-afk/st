        <mxCell id="gXT_r8I7b4ar9Q3fEVYS-20" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#36393d;" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;GitHub Workflow&lt;/font&gt;&lt;/b&gt;" vertex="1">
